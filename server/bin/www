#!/usr/bin/env node

// Carga .env.development o .env.production según entorno NODE_ENV
const envFile = process.env.NODE_ENV === 'production' ? '.env.production' : '.env.development';

require('dotenv').config({ path: envFile });

console.log(`🔧 Entorno: ${process.env.NODE_ENV} → cargando ${envFile}`);

/**
 * Module dependencies.
 */

var app = require('../app');
var debug = require('debug')('server:server');
var http = require('http');


/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
 * Create HTTP server.
 */

var server = http.createServer(app);

/**
 * Listen on provided port, on all network interfaces.
 */

server.listen(port);
server.on('error', onError);
server.on('listening', onListening);

// ── Timeouts para SSE de larga duración (migraciones SP→ACC) ──
// Node.js >= 18 tiene requestTimeout = 300s por defecto, que corta SSE.
// Lo deshabilitamos a nivel de servidor; cada ruta SSE también lo hace individualmente.
server.timeout = 0;                     // 0 = sin timeout de inactividad
server.requestTimeout = 0;              // 0 = sin timeout de request
server.headersTimeout = 0;              // 0 = sin timeout de headers
server.keepAliveTimeout = 120_000;      // 2min keepalive entre requests

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  var bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  debug('Listening on ' + bind);
}
